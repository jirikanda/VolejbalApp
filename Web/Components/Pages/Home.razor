@page "/"

<PageTitle>Volejbal - Přihlašování</PageTitle>

@if (ShowNastenkaLink)
{
    <a href="/Nastenka" class="text-danger fw-semibold d-block mb-2">Na nástěnce jsou nové vzkazy!</a>
}

<KandaEu.Volejbal.Web.Components.Pages.Terminy.Terminy CurrentTerminIdChanged="HandleCurrentTerminIdChanged" />
