<div class="d-flex flex-wrap gap-2 mt-3">
    <a href="/Nastenka" class="btn btn-danger nav-btn">
        <i class="bi bi-chat-dots me-1"></i>nástěnka
    </a>
    <a href="/Osoby" class="btn btn-success nav-btn">
        <i class="bi bi-people me-1"></i>správa osob
    </a>
    <a href="/Statistika" class="btn nav-btn" style="background-color:#e3a21a; color:white;">
        <i class="bi bi-bar-chart-horizontal me-1"></i>statistika
    </a>
