    <div class="compose" style="padding: 0; border: 0; background: transparent; box-shadow: none;">
        <HxInputText Label="Jm&#233;no" @bind-Value="@formData.Jmeno" MaxLength="50" Placeholder="Jana" />
        <HxInputText Label="P&#345;&#237;jmen&#237;" @bind-Value="@formData.Prijmeni" MaxLength="50" Placeholder="Nov&#225;kov&#225;" />
