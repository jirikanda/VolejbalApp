<div class="deactivated">
    <h3>Deaktivované osoby</h3>
    <p class="descr">Kdo na volejbale nebyl 2 měsíce, je automaticky deaktivován. Může se zde znovu aktivovat a přihlásit se.</p>

    @if (osoby != null)
    {
        @if (osoby.Osoby.Count == 0)
        {
            <div class="empty-block" style="padding: 24px 16px;">
                <strong>Žádné deaktivované osoby</strong>
                Všichni evidovaní hráči jsou aktivní.
            </div>
        }
        else
        {
            <table>
                <tbody>
                    @foreach (var osoba in osoby.Osoby)
                    {
                        <tr>
                            <td class="name">@osoba.PrijmeniJmeno</td>
                            <td class="actions">
                                <button type="button" class="text-btn activate" @onclick="@(async () => await AktivovatAsync(osoba))">aktivovat</button>
                                <button type="button" class="text-btn del" @onclick="@(async () => await SmazatAsync(osoba))">smazat</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

<HxModal @ref="deleteModal" Title="Smazat osobu" Size="ModalSize.Small">
    <BodyTemplate>
        Opravdu chceš smazat osobu &ldquo;@osobaKeSmazani?.PrijmeniJmeno&rdquo;?
    </BodyTemplate>
    <FooterTemplate>
        <HxButton Text="Zrušit" Color="ThemeColor.Secondary" OnClick="@(async () => await deleteModal.HideAsync())" />
        <HxButton Text="Smazat" Color="ThemeColor.Danger" OnClick="PotvrditSmazaniAsync" />
    </FooterTemplate>
</HxModal>
