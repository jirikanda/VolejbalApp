@if (State.Terminy != null)
{
    @if (State.Terminy.Count == 0)
    {
        <div class="empty-date">&#381;&#225;dn&#253; term&#237;n nen&#237; k&#160;dispozici.</div>
    }
    else
    {
        <div class="dates">
            @foreach (var termin in State.Terminy)
            {
                var isSelected = termin.Id == State.CurrentTerminId;
                <button type="button" class="date"
                        aria-pressed="@(isSelected ? "true" : "false")"
                        @onclick="@(_ => TerminClickAsync(termin))">
                    <div class="d-date">
                        @($"{termin.Datum.Day}.") <small>@CzechMonth(termin.Datum.Month)</small>
                    </div>
                </button>
            }
        </div>
    }
}
