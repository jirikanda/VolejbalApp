@if (State.AktualniTerminId == null)
{
    <p style="margin-top: 20px; color: var(--ink-3); font-style: italic;">Termín není zvolen.</p>
}
else if (State.Prihlaseni != null && State.Neprihlaseni != null)
{
    <div class="roster">
        <div class="roster-col">
            <h3>
                <span class="legend-key" style="background: var(--signed);"></span>
                Přihlášení
                <span class="count">@State.Prihlaseni.Count</span>
            </h3>
            @if (State.Prihlaseni.Count == 0)
            {
                <div class="empty-block" style="padding: 24px 16px;">
                    <strong>Zatím nikdo</strong>
                    Buď první, kdo se přihlásí.
                </div>
            }
            else
            {
                <div class="signed-list">
                    @{ var idx = 0; }
                    @foreach (var prihlaseny in State.Prihlaseni)
                    {
                        idx++;
                        var rowIdx = idx;
                        <div class="signed-row">
                            <span class="idx">@rowIdx</span>
                            <span class="nm @(prihlaseny.Osoba.Id == PrefferedOsobaId ? "preferred" : "")">@prihlaseny.Osoba.PrijmeniJmeno</span>
                            <button type="button" class="unsign"
                                    @onclick="@(async _ => await HandleOdhlasitClickAsync(prihlaseny.Osoba))">
                                odhlásit
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="roster-col">
            <h3>
                Nepřihlášení
                <span class="count">@State.Neprihlaseni.Count</span>
                <span class="legend h3-legend">
                    <span class="l-pending"><i></i>nereagoval</span>
                    <span class="l-decl"><i></i>odmítl</span>
                </span>
            </h3>
            @if (State.Neprihlaseni.Count == 0)
            {
                <div class="empty-block" style="padding: 24px 16px;">
                    <strong>Všichni jsou přihlášeni</strong>
                </div>
            }
            else
            {
                <div class="unsigned-grid">
                    @foreach (var neprihlaseny in State.Neprihlaseni)
                    {
                        var stateClass = neprihlaseny.IsOdhlaseny ? "state-declined" : "state-pending";
                        var avatarColor = neprihlaseny.IsOdhlaseny ? "var(--declined)" : "var(--pending)";
                        <div class="player @stateClass">
                            <div class="avatar" aria-hidden="true" style="background: @avatarColor;">
                                <svg viewBox="0 0 448 512" fill="currentColor">
                                    <path d="M224 256A128 128 0 1 0 224 0a128 128 0 1 0 0 256zm-45.7 48C79.8 304 0 383.8 0 482.3 0 498.7 13.3 512 29.7 512l388.6 0c16.4 0 29.7-13.3 29.7-29.7C448 383.8 368.2 304 269.7 304l-91.4 0z" />
                                </svg>
                            </div>
                            <div class="nm-block">
                                <div class="nm @(neprihlaseny.Osoba.Id == PrefferedOsobaId ? "preferred" : "")">@neprihlaseny.Osoba.PrijmeniJmeno</div>
                            </div>
                            <div class="actions">
                                <button type="button" class="act-sign"
                                        @onclick="@(async _ => await HandlePrihlasitClickAsync(neprihlaseny))">
                                    přihlásit
                                </button>
                                @if (!neprihlaseny.IsOdhlaseny)
                                {
                                    <button type="button" class="act-decline"
                                            @onclick="@(async _ => await HandleOdhlasitClickAsync(neprihlaseny.Osoba))">
                                        nemůžu
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="act-decline" tabindex="-1" aria-hidden="true" style="visibility: hidden;">
                                        nemůžu
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
